// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "profiles": {
    "home": {
      "settings": {
        "edit_predictions": {
          "provider": "zed",
        },
      },
    },
    "work": {
      "settings": {
        "edit_predictions": {
          "provider": "copilot",
        },
      },
    },
  },
  "colorize_brackets": true,
  "tabs": {
    "show_diagnostics": "all",
  },
  "icon_theme": {
    "mode": "light",
    "light": "Catppuccin Macchiato",
    "dark": "Catppuccin Macchiato",
  },
  "completion_menu_item_kind": "symbol",
  "buffer_line_height": {
    "custom": 1.75,
  },
  "excerpt_context_lines": 5,
  "expand_excerpt_lines": 10,
  "cli_default_open_behavior": "new_window",
  "agent_servers": {
    "opencode": {
      "default_config_options": {
        "mode": "build",
        "effort": "medium",
        "model": "opencode/deepseek-v4-flash-free",
      },
      "type": "custom",
      "command": "opencode",
      "args": ["acp"],
      "env": {
        "GOOGLE_APPLICATION_CREDENTIALS": "/Users/ejvzx/.config/gcloud/application_default_credentials.json",
        "GOOGLE_CLOUD_PROJECT": "bcs-ely-ops",
        "VERTEX_LOCATION": "global",
      },
    },
    "codex-acp": {
      "type": "registry",
    },
    "cursor": {
      "default_config_options": {
        "model": "default[]",
      },
      "type": "registry",
    },
    "csgdaa-code": {
      "type": "custom",
      "command": "csgdaa-code",
      "args": ["--acp"],
    },
  },
  "vim_mode": true,
  "project_panel": {
    "dock": "left",
  },
  "outline_panel": {
    "dock": "left",
  },
  "collaboration_panel": {
    "dock": "left",
  },
  "agent": {
    "terminal_init_command": "pi",
    "tool_permissions": {
      "tools": {
        "search_web": {
          "default": "allow",
        },
        "fetch": {
          "default": "allow",
        },
      },
    },
    "thinking_display": "preview",
    "dock": "right",
    "favorite_models": [],
    "model_parameters": [],
  },
  "git_panel": {
    "dock": "left",
  },
  "ui_font_size": 13.0,
  "buffer_font_size": 12.0,
  "theme": {
    "mode": "dark",
    "light": "One Light",
    "dark": "Catppuccin Macchiato - No Italics",
  },
  "wrap_guides": [120],
  "file_types": {
    "SQL": ["**/*.ddl", "**/*.dml"],
  },
  "file_finder": {
    "modal_max_width": "large",
  },
  "languages": {
    "PHP": {
      "language_servers": [
        "phpantom_lsp",
        "!intelephense",
        "!phpactor",
        "!phptools",
        "...",
      ],
      "formatter": {
        "external": {
          "command": "mago",
          "arguments": ["format", "--stdin-input"],
        },
      },
    },
    "Python": {
      "language_servers": [
        // Enable ty, disable basedpyright, and enable all
        // other registered language servers (ruff, pylsp, pyright).
        "ty",
        "!basedpyright",
        "!pyright",
        "...",
      ],
    },
  },
  "lsp": {
    "golangci-lint": {
      "initialization_options": {
        "command": [
          "golangci-lint",
          "run",
          "--output.json.path=stdout",
          "--show-stats=false",
          "--issues-exit-code=1",
        ],
      },
    },
    "gopls": {
      "initialization_options": {
        "gofumpt": true
      }
    },
    "intelephense": {
      "initialization_options": {
        "licenceKey": "~/.config/intelephense/licence.txt",
      },
    },
  },
}
