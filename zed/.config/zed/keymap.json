// Lots of good suggestions found here
// https://gist.github.com/oca159/0b480ed6555056418905b6e59af33674
[
  {
    "context": "VimControl && !menu",
    "bindings": {
      "\\": "project_panel::Toggle",
      "g y": "editor::CopyPermalinkToLine",
      "g r d": "editor::GoToDefinition",
      "g r shift-d": "editor::GoToDeclaration",
      "s": "vim::PushSneak",
      "shift-s": "vim::PushSneakBackward",
    },
  },
  {
    "context": "Editor && VimControl && !VimWaiting && !menu",
    "bindings": {
      "ctrl-l": "workspace::ActivatePaneRight",
      "ctrl-h": "workspace::ActivatePaneLeft",
      "ctrl-k": "workspace::ActivatePaneUp",
      "ctrl-j": "workspace::ActivatePaneDown",
      "ctrl-y": "editor::ConfirmCompletion",
      "ctrl-shift-l": "editor::AcceptNextWordEditPrediction",
      "space space": "file_finder::Toggle",
      "space s f": "file_finder::Toggle",
      "space s g": "workspace::NewSearch",
      // Chat with AI
      "space a a": "agent::ToggleFocus",
      "space a e": "assistant::InlineAssist",
      "space a t": "workspace::ToggleRightDock",
      "space o": "outline_panel::Toggle",
    },
  },
  {
    "context": "EmptyPane || SharedScreen || (ProjectPanel && not_editing)",
    "bindings": {
      "\\": "project_panel::Toggle",
    },
  },
]
